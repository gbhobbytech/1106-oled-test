idiv(y, 8)\n    let index = page * 128 + x\n    let mask = 1 << (y % 8)\n\n    if (on) {\n        fb[index] = fb[index] | mask\n    } else {\n        fb[index] = fb[index] & (~mask)\n    }\n}\n\nfunction showScreen() {\n    for (let page = 0; page < 8; page++) {\n        setPage(page)\n        let row = pins.createBuffer(128)\n        for (let x = 0; x < 128; x++) {\n            row[x] = fb[page * 128 + x]\n        }\n        dataBlock(row)\n    }\n}\n\nfunction drawBox(x: number, y: number, w: number, h: number, on: boolean) {\n    for (let yy = y; yy < y + h; yy++) {\n        for (let xx = x; xx < x + w; xx++) {\n            setPixel(xx, yy, on)\n        }\n    }\n}\n\nfunction drawCircle(cx: number, cy: number, r: number) {\n    for (let deg = 0; deg < 360; deg++) {\n        let rad = deg * Math.PI / 180\n        let x = Math.round(cx + r * Math.cos(rad))\n        let y = Math.round(cy + r * Math.sin(rad))\n        setPixel(x, y, true)\n    }\n}\n\nsh1106Init()\nclearScreen()\n\n"]]},{"start1":2125,"length1":5,"diffs":[[1,"    clearScreen()\n\n    // blinking heartbeat on micro:bit\n    led.toggle(2, 2)\n\n    // simple face test\n    drawCircle(64, 32, 28)\n    drawBox(49, 28, 6, 6, true)\n    drawBox(73, 28, 6, 6, true)\n\n    for (let x = 52; x <= 76; x++) {\n        let dx = x - 64\n        let y = 48 + Math.round(dx * dx / 40)\n        setPixel(x, y, true)\n    }\n\n    showScreen()\n    basic.pause(500)\n})"]]}]},{"type":"edited","filename":"pxt.json","patch":[{"start1":237,"length1":44,"diffs":[[1,""]]}]},{"type":"added","filename":"test.ts","value":"// tests go here; this will not be compiled when this package is used as an extension.\n"}]}],"snapshots":[{"timestamp":1774238963759,"editorVersion":"8.0.18","text":{"main.blocks":"<xml xmlns=\"http://www.w3.org/1999/xhtml\">\n  <block type=\"pxt-on-start\"></block>\n  <block type=\"device_forever\"></block>\n</xml>","main.ts":"\n","README.md":"","pxt.json":"{\n    \"name\": \"OLED Next test\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"additionalFilePaths\": []\n}\n"}},{"timestamp":1777603089116,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables></variables><block type=\"pxt-on-start\" x=\"20\" y=\"20\"></block><block type=\"device_forever\" x=\"225\" y=\"20\"></block></xml>","main.ts":"const OLED_ADDR = 0x3C\nconst OLED_OFFSET = 2\n\nlet fb = pins.createBuffer(1024)\n\nfunction cmd1(c: number) {\n    let b = pins.createBuffer(2)\n    b[0] = 0x00\n    b[1] = c\n    pins.i2cWriteBuffer(OLED_ADDR, b)\n}\n\nfunction dataBlock(buf: Buffer) {\n    let out = pins.createBuffer(buf.length + 1)\n    out[0] = 0x40\n    for (let i = 0; i < buf.length; i++) {\n        out[i + 1] = buf[i]\n    }\n    pins.i2cWriteBuffer(OLED_ADDR, out)\n}\n\nfunction sh1106Init() {\n    basic.pause(100)\n    cmd1(0xAE)\n    cmd1(0xD5)\n    cmd1(0x80)\n    cmd1(0xA8)\n    cmd1(0x3F)\n    cmd1(0xD3)\n    cmd1(0x00)\n    cmd1(0x40)\n    cmd1(0xA1)\n    cmd1(0xC8)\n    cmd1(0xDA)\n    cmd1(0x12)\n    cmd1(0x81)\n    cmd1(0x7F)\n    cmd1(0xD9)\n    cmd1(0x22)\n    cmd1(0xDB)\n    cmd1(0x20)\n    cmd1(0xA4)\n    cmd1(0xA6)\n    cmd1(0xAF)\n}\n\nfunction setPage(page: number) {\n    cmd1(0xB0 | page)\n    cmd1(OLED_OFFSET & 0x0F)\n    cmd1(0x10 | ((OLED_OFFSET >> 4) & 0x0F))\n}\n\nfunction clearScreen() {\n    for (let i = 0; i < 1024; i++) {\n        fb[i] = 0\n    }\n}\n\nfunction setPixel(x: number, y: number, on: boolean) {\n    if (x < 0 || x > 127 || y < 0 || y > 63) return\n\n    let page = Math.idiv(y, 8)\n    let index = page * 128 + x\n    let mask = 1 << (y % 8)\n\n    if (on) {\n        fb[index] = fb[index] | mask\n    } else {\n        fb[index] = fb[index] & (~mask)\n    }\n}\n\nfunction showScreen() {\n    for (let page = 0; page < 8; page++) {\n        setPage(page)\n        let row = pins.createBuffer(128)\n        for (let x = 0; x < 128; x++) {\n            row[x] = fb[page * 128 + x]\n        }\n        dataBlock(row)\n    }\n}\n\nfunction drawBox(x: number, y: number, w: number, h: number, on: boolean) {\n    for (let yy = y; yy < y + h; yy++) {\n        for (let xx = x; xx < x + w; xx++) {\n            setPixel(xx, yy, on)\n        }\n    }\n}\n\nfunction drawCircle(cx: number, cy: number, r: number) {\n    for (let deg = 0; deg < 360; deg++) {\n        let rad = deg * Math.PI / 180\n        let x = Math.round(cx + r * Math.cos(rad))\n        let y = Math.round(cy + r * Math.sin(rad))\n        setPixel(x, y, true)\n    }\n}\n\nsh1106Init()\nclearScreen()\n\nbasic.forever(function () {\n    clearScreen()\n\n    // blinking heartbeat on micro:bit\n    led.toggle(2, 2)\n\n    // simple face test\n    drawCircle(64, 32, 28)\n    drawBox(49, 28, 6, 6, true)\n    drawBox(73, 28, 6, 6, true)\n\n    for (let x = 52; x <= 76; x++) {\n        let dx = x - 64\n        let y = 48 + Math.round(dx * dx / 40)\n        setPixel(x, y, true)\n    }\n\n    showScreen()\n    basic.pause(500)\n})","README.md":"","pxt.json":"{\n    \"name\": \"1106 OLED Test\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}}],"shares":[],"lastSaveTime":1777603294016}