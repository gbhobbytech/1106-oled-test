<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="(|8Q`T+YG/a_ShxWk/SH" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="K}t=HY9=%2JHTg-P2ddL"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="" line4="    let buffer = pins.createBuffer(1024)" line5="    let started = false" line6="" line7="    function cmd(c: number): void {" line8="        let b = pins.createBuffer(2)" line9="        b[0] = 0x00" line10="        b[1] = c" line11="        pins.i2cWriteBuffer(OLED_ADDR, b)" line12="    }" line13="" line14="    function data(buf: Buffer): void {" line15="        let out = pins.createBuffer(buf.length + 1)" line16="        out[0] = 0x40" line17="        for (let i = 0; i &lt; buf.length; i++) {" line18="            out[i + 1] = buf[i]" line19="        }" line20="        pins.i2cWriteBuffer(OLED_ADDR, out)" line21="    }" line22="" line23="    function setPage(page: number): void {" line24="        cmd(0xB0 | page)" line25="        cmd(OFFSET &amp; 0x0F)" line26="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line27="    }" line28="" line29="    //% block=&quot;initialise OLED&quot;" line30="    export function init(): void {" line31="        basic.pause(100)" line32="" line33="        cmd(0xAE)              // display off" line34="        cmd(0xD5); cmd(0x80)   // clock divide" line35="        cmd(0xA8); cmd(0x3F)   // multiplex ratio 64" line36="        cmd(0xD3); cmd(0x00)   // display offset" line37="        cmd(0x40)              // display start line" line38="        cmd(0xA1)              // segment remap" line39="        cmd(0xC8)              // COM scan direction" line40="        cmd(0xDA); cmd(0x12)   // COM pins" line41="        cmd(0x81); cmd(0x7F)   // contrast" line42="        cmd(0xD9); cmd(0x22)   // pre-charge" line43="        cmd(0xDB); cmd(0x20)   // VCOMH deselect" line44="        cmd(0xA4)              // resume display from RAM" line45="        cmd(0xA6)              // normal display" line46="        cmd(0xAF)              // display on" line47="" line48="        started = true" line49="        clear()" line50="        show()" line51="    }" line52="" line53="    //% block=&quot;clear OLED buffer&quot;" line54="    export function clear(): void {" line55="        for (let j = 0; j &lt; 1024; j++) {" line56="            buffer[j] = 0" line57="        }" line58="    }" line59="" line60="    //% block=&quot;fill OLED buffer %on&quot;" line61="    export function fill(on: boolean): void {" line62="        let value = on ? 0xFF : 0x00" line63="        for (let k = 0; k &lt; 1024; k++) {" line64="            buffer[k] = value" line65="        }" line66="    }" line67="" line68="    //% block=&quot;show OLED&quot;" line69="    export function show(): void {" line70="        if (!started) {" line71="            init()" line72="            return" line73="        }" line74="" line75="        for (let page = 0; page &lt; 8; page++) {" line76="            setPage(page)" line77="" line78="            let row = pins.createBuffer(128)" line79="            for (let x = 0; x &lt; 128; x++) {" line80="                row[x] = buffer[page * 128 + x]" line81="            }" line82="" line83="            data(row)" line84="        }" line85="    }" line86="" line87="    //% block=&quot;plot OLED pixel x %x y %y on %on&quot;" line88="    //% x.min=0 x.max=127 y.min=0 y.max=63" line89="    export function pixel(x: number, y: number, on: boolean): void {" line90="        if (x &lt; 0 || x &gt; 127 || y &lt; 0 || y &gt; 63) {" line91="            return" line92="        }" line93="" line94="        let page2 = Math.idiv(y, 8)" line95="        let index = page2 * 128 + x" line96="        let mask = 1 &lt;&lt; (y % 8)" line97="" line98="        if (on) {" line99="            buffer[index] = buffer[index] | mask" line100="        } else {" line101="            buffer[index] = buffer[index] &amp; ~mask" line102="        }" line103="    }" line104="" line105="    //% block=&quot;draw line x0 %x0 y0 %y0 x1 %x1 y1 %y1 on %on&quot;" line106="    //% x0.min=0 x0.max=127 y0.min=0 y0.max=63" line107="    //% x1.min=0 x1.max=127 y1.min=0 y1.max=63" line108="    export function line(x0: number, y0: number, x1: number, y1: number, on: boolean = true): void {" line109="        let dx = Math.abs(x1 - x0)" line110="        let sx = x0 &lt; x1 ? 1 : -1" line111="        let dy = -Math.abs(y1 - y0)" line112="        let sy = y0 &lt; y1 ? 1 : -1" line113="        let err = dx + dy" line114="" line115="        while (true) {" line116="            pixel(x0, y0, on)" line117="" line118="            if (x0 == x1 &amp;&amp; y0 == y1) {" line119="                break" line120="            }" line121="" line122="            let e2 = 2 * err" line123="" line124="            if (e2 &gt;= dy) {" line125="                err += dy" line126="                x0 += sx" line127="            }" line128="" line129="            if (e2 &lt;= dx) {" line130="                err += dx" line131="                y0 += sy" line132="            }" line133="        }" line134="    }" line135="" line136="    //% block=&quot;draw rectangle x %x y %y w %w h %h on %on&quot;" line137="    //% x.min=0 x.max=127 y.min=0 y.max=63" line138="    //% w.min=0 w.max=127 h.min=0 h.max=63" line139="    export function rect(x: number, y: number, w: number, h: number, on: boolean = true): void {" line140="        line(x, y, x + w, y, on)" line141="        line(x, y, x, y + h, on)" line142="        line(x + w, y, x + w, y + h, on)" line143="        line(x, y + h, x + w, y + h, on)" line144="    }" line145="" line146="    function fillRect(x: number, y: number, w: number, h: number, on: boolean): void {" line147="        for (let yy = y; yy &lt; y + h; yy++) {" line148="            for (let xx = x; xx &lt; x + w; xx++) {" line149="                pixel(xx, yy, on)" line150="            }" line151="        }" line152="    }" line153="" line154="    const font5x7: number[] = [" line155="        0x00, 0x00, 0x00, 0x00, 0x00, // space" line156="        0x00, 0x00, 0x5F, 0x00, 0x00, // !" line157="        0x00, 0x07, 0x00, 0x07, 0x00, // &quot;" line158="        0x14, 0x7F, 0x14, 0x7F, 0x14, // #" line159="        0x24, 0x2A, 0x7F, 0x2A, 0x12, // $" line160="        0x23, 0x13, 0x08, 0x64, 0x62, // %" line161="        0x36, 0x49, 0x55, 0x22, 0x50, // &amp;" line162="        0x00, 0x05, 0x03, 0x00, 0x00, // '" line163="        0x00, 0x1C, 0x22, 0x41, 0x00, // (" line164="        0x00, 0x41, 0x22, 0x1C, 0x00, // )" line165="        0x14, 0x08, 0x3E, 0x08, 0x14, // *" line166="        0x08, 0x08, 0x3E, 0x08, 0x08, // +" line167="        0x00, 0x50, 0x30, 0x00, 0x00, // ," line168="        0x08, 0x08, 0x08, 0x08, 0x08, // -" line169="        0x00, 0x60, 0x60, 0x00, 0x00, // ." line170="        0x20, 0x10, 0x08, 0x04, 0x02, // /" line171="        0x3E, 0x51, 0x49, 0x45, 0x3E, // 0" line172="        0x00, 0x42, 0x7F, 0x40, 0x00, // 1" line173="        0x42, 0x61, 0x51, 0x49, 0x46, // 2" line174="        0x21, 0x41, 0x45, 0x4B, 0x31, // 3" line175="        0x18, 0x14, 0x12, 0x7F, 0x10, // 4" line176="        0x27, 0x45, 0x45, 0x45, 0x39, // 5" line177="        0x3C, 0x4A, 0x49, 0x49, 0x30, // 6" line178="        0x01, 0x71, 0x09, 0x05, 0x03, // 7" line179="        0x36, 0x49, 0x49, 0x49, 0x36, // 8" line180="        0x06, 0x49, 0x49, 0x29, 0x1E, // 9" line181="        0x00, 0x36, 0x36, 0x00, 0x00, // :" line182="        0x00, 0x56, 0x36, 0x00, 0x00, // ;" line183="        0x08, 0x14, 0x22, 0x41, 0x00, // &lt;" line184="        0x14, 0x14, 0x14, 0x14, 0x14, // =" line185="        0x00, 0x41, 0x22, 0x14, 0x08, // &gt;" line186="        0x02, 0x01, 0x51, 0x09, 0x06, // ?" line187="        0x32, 0x49, 0x79, 0x41, 0x3E, // @" line188="        0x7E, 0x11, 0x11, 0x11, 0x7E, // A" line189="        0x7F, 0x49, 0x49, 0x49, 0x36, // B" line190="        0x3E, 0x41, 0x41, 0x41, 0x22, // C" line191="        0x7F, 0x41, 0x41, 0x22, 0x1C, // D" line192="        0x7F, 0x49, 0x49, 0x49, 0x41, // E" line193="        0x7F, 0x09, 0x09, 0x09, 0x01, // F" line194="        0x3E, 0x41, 0x49, 0x49, 0x7A, // G" line195="        0x7F, 0x08, 0x08, 0x08, 0x7F, // H" line196="        0x00, 0x41, 0x7F, 0x41, 0x00, // I" line197="        0x20, 0x40, 0x41, 0x3F, 0x01, // J" line198="        0x7F, 0x08, 0x14, 0x22, 0x41, // K" line199="        0x7F, 0x40, 0x40, 0x40, 0x40, // L" line200="        0x7F, 0x02, 0x0C, 0x02, 0x7F, // M" line201="        0x7F, 0x04, 0x08, 0x10, 0x7F, // N" line202="        0x3E, 0x41, 0x41, 0x41, 0x3E, // O" line203="        0x7F, 0x09, 0x09, 0x09, 0x06, // P" line204="        0x3E, 0x41, 0x51, 0x21, 0x5E, // Q" line205="        0x7F, 0x09, 0x19, 0x29, 0x46, // R" line206="        0x46, 0x49, 0x49, 0x49, 0x31, // S" line207="        0x01, 0x01, 0x7F, 0x01, 0x01, // T" line208="        0x3F, 0x40, 0x40, 0x40, 0x3F, // U" line209="        0x1F, 0x20, 0x40, 0x20, 0x1F, // V" line210="        0x3F, 0x40, 0x38, 0x40, 0x3F, // W" line211="        0x63, 0x14, 0x08, 0x14, 0x63, // X" line212="        0x07, 0x08, 0x70, 0x08, 0x07, // Y" line213="        0x61, 0x51, 0x49, 0x45, 0x43  // Z" line214="    ]" line215="" line216="    function drawChar(ch: string, x: number, y: number, size: number, on: boolean): void {" line217="        let code = ch.charCodeAt(0)" line218="" line219="        if (code &gt;= 97 &amp;&amp; code &lt;= 122) {" line220="            code -= 32" line221="        }" line222="" line223="        if (code &lt; 32 || code &gt; 90) {" line224="            code = 63" line225="        }" line226="" line227="        let index2 = (code - 32) * 5" line228="" line229="        for (let col = 0; col &lt; 5; col++) {" line230="            let lineBits = font5x7[index2 + col]" line231="" line232="            for (let row2 = 0; row2 &lt; 7; row2++) {" line233="                if ((lineBits &amp; (1 &lt;&lt; row2)) != 0) {" line234="                    if (size &lt;= 1) {" line235="                        pixel(x + col, y + row2, on)" line236="                    } else {" line237="                        fillRect(x + col * size, y + row2 * size, size, size, on)" line238="                    }" line239="                }" line240="            }" line241="        }" line242="    }" line243="" line244="    //% block=&quot;draw text %message x %x y %y size %size on %on&quot;" line245="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line246="    export function text(message: string, x: number, y: number, size: number = 1, on: boolean = true): void {" line247="        if (size &lt; 1) {" line248="            size = 1" line249="        }" line250="        if (size &gt; 4) {" line251="            size = 4" line252="        }" line253="" line254="        for (let l = 0; l &lt; message.length; l++) {" line255="            drawChar(message.charAt(l), x + l * 6 * size, y, size, on)" line256="        }" line257="    }" line258="}" numlines="259"></mutation></block></statement></block></xml>