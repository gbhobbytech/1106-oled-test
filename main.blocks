<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="xRRgvHNlG#rZ^u`HECiY" x="32" y="49"><statement name="HANDLER"><block type="typescript_statement" id="FAbT2xHXcl5VyYOGv6+U"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="" line4="    function cmd(c: number) {" line5="        let b = pins.createBuffer(2)" line6="        b[0] = 0x00" line7="        b[1] = c" line8="        pins.i2cWriteBuffer(OLED_ADDR, b)" line9="    }" line10="" line11="    function data(buf: Buffer) {" line12="        let out = pins.createBuffer(buf.length + 1)" line13="        out[0] = 0x40" line14="        for (let i = 0; i &lt; buf.length; i++) {" line15="            out[i + 1] = buf[i]" line16="        }" line17="        pins.i2cWriteBuffer(OLED_ADDR, out)" line18="    }" line19="" line20="    function setPage(page: number) {" line21="        cmd(0xB0 | page)" line22="        cmd(OFFSET &amp; 0x0F)" line23="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line24="    }" line25="" line26="    //% block=&quot;initialise OLED&quot;" line27="    export function init(): void {" line28="        basic.pause(100)" line29="        cmd(0xAE)" line30="        cmd(0xD5); cmd(0x80)" line31="        cmd(0xA8); cmd(0x3F)" line32="        cmd(0xD3); cmd(0x00)" line33="        cmd(0x40)" line34="        cmd(0xA1)" line35="        cmd(0xC8)" line36="        cmd(0xDA); cmd(0x12)" line37="        cmd(0x81); cmd(0x7F)" line38="        cmd(0xD9); cmd(0x22)" line39="        cmd(0xDB); cmd(0x20)" line40="        cmd(0xA4)" line41="        cmd(0xA6)" line42="        cmd(0xAF)" line43="    }" line44="" line45="    //% block=&quot;fill OLED %on&quot;" line46="    export function fill(on: boolean): void {" line47="        let value = on ? 0xFF : 0x00" line48="" line49="        let row = pins.createBuffer(128)" line50="        for (let j = 0; j &lt; 128; j++) {" line51="            row[j] = value" line52="        }" line53="" line54="        for (let page = 0; page &lt; 8; page++) {" line55="            setPage(page)" line56="            data(row)" line57="        }" line58="    }" line59="}" numlines="60"></mutation><next><block type="oled_init" id="mpjubu(C-_UB^$`m#wx_"></block></next></block></statement></block><block type="device_forever" id="Qh?!Ud:?J:ml).HS_jPm" x="704" y="1926"><statement name="HANDLER"><block type="oled_fill" id=",W~dL%9fL6L%w,uVUO@-"><value name="on"><shadow type="logic_boolean" id="4)d_?@uJz.0?!w@wXF$I"><field name="BOOL">TRUE</field></shadow></value><next><block type="device_pause" id="gb)/=KR=63boJB)).;um"><value name="pause"><shadow type="timePicker" id="^$U$}lh`RQqoT4GHAP.]"><field name="ms">100</field></shadow></value><next><block type="oled_fill" id="LM`sG)@*~;o^}1J`v2vE"><value name="on"><shadow type="logic_boolean" id="SXc)z$H+};AE|p2kJ=Uc"><field name="BOOL">FALSE</field></shadow></value><next><block type="device_pause" id="+gi9Cosa,9C``?l.MYA="><value name="pause"><shadow type="timePicker" id="Ug%k[=zVz/)szBrK7Zws"><field name="ms">100</field></shadow></value></block></next></block></next></block></next></block></statement></block></xml>