<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="^=:~}M?~;/~Lo;@*7`;=" x="48" y="53"><statement name="HANDLER"><block type="typescript_statement" id="Ath?ybrpt29G^B@9,N_o"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum ArcDirection {" line1="    //% block=&quot;up&quot;" line2="    Up," line3="    //% block=&quot;down&quot;" line4="    Down" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="awn;cj#~:l8iF(P(s.^@"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="" line4="    let buffer = pins.createBuffer(1024)" line5="    let started = false" line6="" line7="    function cmd(c: number): void {" line8="        let b = pins.createBuffer(2)" line9="        b[0] = 0x00" line10="        b[1] = c" line11="        pins.i2cWriteBuffer(OLED_ADDR, b)" line12="    }" line13="" line14="    function data(buf: Buffer): void {" line15="        let out = pins.createBuffer(buf.length + 1)" line16="        out[0] = 0x40" line17="        for (let i = 0; i &lt; buf.length; i++) {" line18="            out[i + 1] = buf[i]" line19="        }" line20="        pins.i2cWriteBuffer(OLED_ADDR, out)" line21="    }" line22="" line23="    function setPage(page: number): void {" line24="        cmd(0xB0 | page)" line25="        cmd(OFFSET &amp; 0x0F)" line26="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line27="    }" line28="" line29="    //% block=&quot;initialise OLED&quot;" line30="    //% group=&quot;Basic&quot;" line31="    export function init(): void {" line32="        basic.pause(100)" line33="" line34="        cmd(0xAE)              // display off" line35="        cmd(0xD5); cmd(0x80)   // clock divide" line36="        cmd(0xA8); cmd(0x3F)   // multiplex ratio 64" line37="        cmd(0xD3); cmd(0x00)   // display offset" line38="        cmd(0x40)              // display start line" line39="        cmd(0xA1)              // segment remap" line40="        cmd(0xC8)              // COM scan direction" line41="        cmd(0xDA); cmd(0x12)   // COM pins" line42="        cmd(0x81); cmd(0x7F)   // contrast" line43="        cmd(0xD9); cmd(0x22)   // pre-charge" line44="        cmd(0xDB); cmd(0x20)   // VCOMH deselect" line45="        cmd(0xA4)              // resume display from RAM" line46="        cmd(0xA6)              // normal display" line47="        cmd(0xAF)              // display on" line48="" line49="        started = true" line50="        clear()" line51="        show()" line52="    }" line53="" line54="    //% block=&quot;clear drawing&quot;" line55="    //% group=&quot;Advanced&quot;" line56="    export function clear(): void {" line57="        for (let j = 0; j &lt; 1024; j++) {" line58="            buffer[j] = 0" line59="        }" line60="    }" line61="" line62="    //% block=&quot;fill screen %on&quot;" line63="    //% group=&quot;Advanced&quot;" line64="    export function fill(on: boolean): void {" line65="        let value = on ? 0xFF : 0x00" line66="        for (let k = 0; k &lt; 1024; k++) {" line67="            buffer[k] = value" line68="        }" line69="    }" line70="" line71="    //% block=&quot;update OLED&quot;" line72="    //% group=&quot;Basic&quot;" line73="    export function show(): void {" line74="        if (!started) {" line75="            init()" line76="            return" line77="        }" line78="" line79="        for (let page = 0; page &lt; 8; page++) {" line80="            setPage(page)" line81="" line82="            let row = pins.createBuffer(128)" line83="            for (let x = 0; x &lt; 128; x++) {" line84="                row[x] = buffer[page * 128 + x]" line85="            }" line86="" line87="            data(row)" line88="        }" line89="    }" line90="" line91="    //% block=&quot;plot pixel x %x y %y on %on&quot;" line92="    //% group=&quot;Advanced&quot;" line93="    //% x.min=0 x.max=127 y.min=0 y.max=63" line94="    export function pixel(x: number, y: number, on: boolean): void {" line95="        if (x &lt; 0 || x &gt; 127 || y &lt; 0 || y &gt; 63) {" line96="            return" line97="        }" line98="" line99="        let page2 = Math.idiv(y, 8)" line100="        let index = page2 * 128 + x" line101="        let mask = 1 &lt;&lt; (y % 8)" line102="" line103="        if (on) {" line104="            buffer[index] = buffer[index] | mask" line105="        } else {" line106="            buffer[index] = buffer[index] &amp; ~mask" line107="        }" line108="    }" line109="" line110="    //% block=&quot;draw line from start x %startX y %startY to end x %endX y %endY on %on&quot;" line111="    //% group=&quot;Drawing&quot;" line112="    //% x0.min=0 x0.max=127 y0.min=0 y0.max=63" line113="    //% x1.min=0 x1.max=127 y1.min=0 y1.max=63" line114="    export function line(x0: number, y0: number, x1: number, y1: number, on: boolean = true): void {" line115="        let dx = Math.abs(x1 - x0)" line116="        let sx = x0 &lt; x1 ? 1 : -1" line117="        let dy = -Math.abs(y1 - y0)" line118="        let sy = y0 &lt; y1 ? 1 : -1" line119="        let err = dx + dy" line120="" line121="        while (true) {" line122="            pixel(x0, y0, on)" line123="" line124="            if (x0 == x1 &amp;&amp; y0 == y1) {" line125="                break" line126="            }" line127="" line128="            let e2 = 2 * err" line129="" line130="            if (e2 &gt;= dy) {" line131="                err += dy" line132="                x0 += sx" line133="            }" line134="" line135="            if (e2 &lt;= dx) {" line136="                err += dx" line137="                y0 += sy" line138="            }" line139="        }" line140="    }" line141="" line142="    //% block=&quot;draw rectangle x %x y %y width %w height %h on %on&quot;" line143="    //% group=&quot;Drawing&quot;" line144="    //% x.min=0 x.max=127 y.min=0 y.max=63" line145="    //% w.min=0 w.max=127 h.min=0 h.max=63" line146="    export function rect(x: number, y: number, w: number, h: number, on: boolean = true): void {" line147="        line(x, y, x + w, y, on)" line148="        line(x, y, x, y + h, on)" line149="        line(x + w, y, x + w, y + h, on)" line150="        line(x, y + h, x + w, y + h, on)" line151="    }" line152="" line153="    function fillRect(x: number, y: number, w: number, h: number, on: boolean): void {" line154="        for (let yy = y; yy &lt; y + h; yy++) {" line155="            for (let xx = x; xx &lt; x + w; xx++) {" line156="                pixel(xx, yy, on)" line157="            }" line158="        }" line159="    }" line160="" line161="    //% block=&quot;draw circle x %cx y %cy radius %r on %on&quot;" line162="    //% group=&quot;Drawing&quot;" line163="    //% cx.min=0 cx.max=127 cy.min=0 cy.max=63 r.min=1 r.max=63" line164="    export function circle(cx: number, cy: number, r: number, on: boolean = true): void {" line165="        let x2 = r" line166="        let y = 0" line167="        let err2 = 0" line168="" line169="        while (x2 &gt;= y) {" line170="            pixel(cx + x2, cy + y, on)" line171="            pixel(cx + y, cy + x2, on)" line172="            pixel(cx - y, cy + x2, on)" line173="            pixel(cx - x2, cy + y, on)" line174="            pixel(cx - x2, cy - y, on)" line175="            pixel(cx - y, cy - x2, on)" line176="            pixel(cx + y, cy - x2, on)" line177="            pixel(cx + x2, cy - y, on)" line178="" line179="            y += 1" line180="" line181="            if (err2 &lt;= 0) {" line182="                err2 += 2 * y + 1" line183="            } else {" line184="                x2 -= 1" line185="                err2 += 2 * (y - x2) + 1" line186="            }" line187="        }" line188="    }" line189="    " line190="    //% block=&quot;draw arc from start x %x0 y %y0 to end x %x1 y %y1 height %height direction %direction on %on&quot;" line191="    //% group=&quot;Drawing&quot;" line192="    //% x0.min=0 x0.max=127 y0.min=0 y0.max=63" line193="    //% x1.min=0 x1.max=127 y1.min=0 y1.max=63" line194="    //% height.min=0 height.max=63" line195="    export function arc(x0: number, y0: number, x1: number, y1: number, height: number, direction: ArcDirection, on: boolean = true): void {" line196="        if (height &lt; 0) {" line197="            height = 0" line198="        }" line199="" line200="        let midX = Math.idiv(x0 + x1, 2)" line201="        let midY = Math.idiv(y0 + y1, 2)" line202="" line203="        let controlX = midX" line204="        let controlY = midY" line205="" line206="        // A quadratic curve only reaches about half way toward the control point." line207="        // Doubling this makes the visible arc height match the height entered." line208="        let controlHeight = height * 2" line209="" line210="        if (direction == ArcDirection.Up) {" line211="            controlY = midY - controlHeight" line212="        } else {" line213="            controlY = midY + controlHeight" line214="        }" line215="" line216="        let dx2 = Math.abs(x1 - x0)" line217="        let dy2 = Math.abs(y1 - y0)" line218="        let steps = dx2" line219="" line220="        if (dy2 &gt; steps) {" line221="            steps = dy2" line222="        }" line223="" line224="        steps = steps * 2" line225="" line226="        if (steps &lt; 1) {" line227="            steps = 1" line228="        }" line229="" line230="        let lastX = x0" line231="        let lastY = y0" line232="" line233="        for (let l = 1; l &lt;= steps; l++) {" line234="            let t = l / steps" line235="            let oneMinusT = 1 - t" line236="" line237="            let x3 = Math.round(" line238="                oneMinusT * oneMinusT * x0 +" line239="                2 * oneMinusT * t * controlX +" line240="                t * t * x1" line241="            )" line242="" line243="            let y2 = Math.round(" line244="                oneMinusT * oneMinusT * y0 +" line245="                2 * oneMinusT * t * controlY +" line246="                t * t * y1" line247="            )" line248="" line249="            line(lastX, lastY, x3, y2, on)" line250="" line251="            lastX = x3" line252="            lastY = y2" line253="        }" line254="    }" line255="" line256="    //% block=&quot;draw solid circle x %cx y %cy radius %r on %on&quot;" line257="    //% group=&quot;Drawing&quot;" line258="    //% cx.min=0 cx.max=127 cy.min=0 cy.max=63 r.min=1 r.max=63" line259="    export function fillCircle(cx: number, cy: number, r: number, on: boolean = true): void {" line260="        for (let y22 = -r; y22 &lt;= r; y22++) {" line261="            for (let x32 = -r; x32 &lt;= r; x32++) {" line262="                if (x32 * x32 + y22 * y22 &lt;= r * r) {" line263="                    pixel(cx + x32, cy + y22, on)" line264="                }" line265="            }" line266="        }" line267="    }" line268="" line269="    const font5x7: number[] = [" line270="        0x00, 0x00, 0x00, 0x00, 0x00, // space" line271="        0x00, 0x00, 0x5F, 0x00, 0x00, // !" line272="        0x00, 0x07, 0x00, 0x07, 0x00, // &quot;" line273="        0x14, 0x7F, 0x14, 0x7F, 0x14, // #" line274="        0x24, 0x2A, 0x7F, 0x2A, 0x12, // $" line275="        0x23, 0x13, 0x08, 0x64, 0x62, // %" line276="        0x36, 0x49, 0x55, 0x22, 0x50, // &amp;" line277="        0x00, 0x05, 0x03, 0x00, 0x00, // '" line278="        0x00, 0x1C, 0x22, 0x41, 0x00, // (" line279="        0x00, 0x41, 0x22, 0x1C, 0x00, // )" line280="        0x14, 0x08, 0x3E, 0x08, 0x14, // *" line281="        0x08, 0x08, 0x3E, 0x08, 0x08, // +" line282="        0x00, 0x50, 0x30, 0x00, 0x00, // ," line283="        0x08, 0x08, 0x08, 0x08, 0x08, // -" line284="        0x00, 0x60, 0x60, 0x00, 0x00, // ." line285="        0x20, 0x10, 0x08, 0x04, 0x02, // /" line286="        0x3E, 0x51, 0x49, 0x45, 0x3E, // 0" line287="        0x00, 0x42, 0x7F, 0x40, 0x00, // 1" line288="        0x42, 0x61, 0x51, 0x49, 0x46, // 2" line289="        0x21, 0x41, 0x45, 0x4B, 0x31, // 3" line290="        0x18, 0x14, 0x12, 0x7F, 0x10, // 4" line291="        0x27, 0x45, 0x45, 0x45, 0x39, // 5" line292="        0x3C, 0x4A, 0x49, 0x49, 0x30, // 6" line293="        0x01, 0x71, 0x09, 0x05, 0x03, // 7" line294="        0x36, 0x49, 0x49, 0x49, 0x36, // 8" line295="        0x06, 0x49, 0x49, 0x29, 0x1E, // 9" line296="        0x00, 0x36, 0x36, 0x00, 0x00, // :" line297="        0x00, 0x56, 0x36, 0x00, 0x00, // ;" line298="        0x08, 0x14, 0x22, 0x41, 0x00, // &lt;" line299="        0x14, 0x14, 0x14, 0x14, 0x14, // =" line300="        0x00, 0x41, 0x22, 0x14, 0x08, // &gt;" line301="        0x02, 0x01, 0x51, 0x09, 0x06, // ?" line302="        0x32, 0x49, 0x79, 0x41, 0x3E, // @" line303="        0x7E, 0x11, 0x11, 0x11, 0x7E, // A" line304="        0x7F, 0x49, 0x49, 0x49, 0x36, // B" line305="        0x3E, 0x41, 0x41, 0x41, 0x22, // C" line306="        0x7F, 0x41, 0x41, 0x22, 0x1C, // D" line307="        0x7F, 0x49, 0x49, 0x49, 0x41, // E" line308="        0x7F, 0x09, 0x09, 0x09, 0x01, // F" line309="        0x3E, 0x41, 0x49, 0x49, 0x7A, // G" line310="        0x7F, 0x08, 0x08, 0x08, 0x7F, // H" line311="        0x00, 0x41, 0x7F, 0x41, 0x00, // I" line312="        0x20, 0x40, 0x41, 0x3F, 0x01, // J" line313="        0x7F, 0x08, 0x14, 0x22, 0x41, // K" line314="        0x7F, 0x40, 0x40, 0x40, 0x40, // L" line315="        0x7F, 0x02, 0x0C, 0x02, 0x7F, // M" line316="        0x7F, 0x04, 0x08, 0x10, 0x7F, // N" line317="        0x3E, 0x41, 0x41, 0x41, 0x3E, // O" line318="        0x7F, 0x09, 0x09, 0x09, 0x06, // P" line319="        0x3E, 0x41, 0x51, 0x21, 0x5E, // Q" line320="        0x7F, 0x09, 0x19, 0x29, 0x46, // R" line321="        0x46, 0x49, 0x49, 0x49, 0x31, // S" line322="        0x01, 0x01, 0x7F, 0x01, 0x01, // T" line323="        0x3F, 0x40, 0x40, 0x40, 0x3F, // U" line324="        0x1F, 0x20, 0x40, 0x20, 0x1F, // V" line325="        0x3F, 0x40, 0x38, 0x40, 0x3F, // W" line326="        0x63, 0x14, 0x08, 0x14, 0x63, // X" line327="        0x07, 0x08, 0x70, 0x08, 0x07, // Y" line328="        0x61, 0x51, 0x49, 0x45, 0x43  // Z" line329="    ]" line330="" line331="    function drawChar(ch: string, x: number, y: number, size: number, on: boolean): void {" line332="        let code = ch.charCodeAt(0)" line333="" line334="        if (code &gt;= 97 &amp;&amp; code &lt;= 122) {" line335="            code -= 32" line336="        }" line337="" line338="        if (code &lt; 32 || code &gt; 90) {" line339="            code = 63" line340="        }" line341="" line342="        let index2 = (code - 32) * 5" line343="" line344="        for (let col = 0; col &lt; 5; col++) {" line345="            let lineBits = font5x7[index2 + col]" line346="" line347="            for (let row2 = 0; row2 &lt; 7; row2++) {" line348="                if ((lineBits &amp; (1 &lt;&lt; row2)) != 0) {" line349="                    if (size &lt;= 1) {" line350="                        pixel(x + col, y + row2, on)" line351="                    } else {" line352="                        fillRect(x + col * size, y + row2 * size, size, size, on)" line353="                    }" line354="                }" line355="            }" line356="        }" line357="    }" line358="" line359="    //% block=&quot;show text %message x %x y %y size %size&quot;" line360="    //% group=&quot;Basic&quot;" line361="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line362="    export function showText(message: string, x: number, y: number, size: number = 1): void {" line363="        if (!started) {" line364="            init()" line365="        }" line366="" line367="        clear()" line368="        text(message, x, y, size, true)" line369="        show()" line370="    }" line371="" line372="    //% block=&quot;draw text %message x %x y %y size %size on %on&quot;" line373="    //% group=&quot;Advanced&quot;" line374="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line375="    export function text(message: string, x: number, y: number, size: number = 1, on: boolean = true): void {" line376="        if (size &lt; 1) {" line377="            size = 1" line378="        }" line379="        if (size &gt; 4) {" line380="            size = 4" line381="        }" line382="" line383="        for (let m = 0; m &lt; message.length; m++) {" line384="            drawChar(message.charAt(m), x + m * 6 * size, y, size, on)" line385="        }" line386="    }" line387="" line388="}" numlines="389"></mutation><next><block type="oled_init" id="3~Z7$Vb-sZ1(tRiq[jc$"></block></next></block></next></block></statement></block><block type="device_button_event" id="KpkdBB!aal|K#?@Mf1Pn" x="711" y="15898"><field name="NAME">Button.A</field><statement name="HANDLER"><block type="oled_arc" id="szeqs2hXC-i+%,3v,7C~"><field name="direction">ArcDirection.Up</field><value name="x0"><shadow type="math_number_minmax" id="U@eJ?~`hiJ1dMMX`TcB1"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">0</field></shadow></value><value name="y0"><shadow type="math_number_minmax" id="OFED/|-LVIGulY@_0kum"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">63</field></shadow></value><value name="x1"><shadow type="math_number_minmax" id="8]3Qx!vxwa)%G?_y~V17"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">127</field></shadow></value><value name="y1"><shadow type="math_number_minmax" id="y@k0krO5P_qAO^EXH%^V"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">63</field></shadow></value><value name="height"><shadow type="math_number_minmax" id="g7lUvo;nQnUFrxX+fhDg"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">63</field></shadow></value><value name="on"><shadow type="logic_boolean" id="a.CTrlVC.5e3^.nIalc0"><field name="BOOL">TRUE</field></shadow></value><next><block type="oled_show" id="C`*;l4.NAL^JfVZS$1d9"><next><block type="device_pause" id="0vXjH/2quveIGf4ZdVW="><value name="pause"><shadow type="timePicker" id="d{FV]*I7t?)KdE~ik2Q."><field name="ms">1000</field></shadow></value></block></next></block></next></block></statement></block><block type="device_forever" id="UyXRiqGxD#.u0exZwJq*" x="255" y="15941"><statement name="HANDLER"><block type="oled_arc" id="pJiwDfs#P{Dvg;fV%yDg"><field name="direction">ArcDirection.Down</field><value name="x0"><shadow type="math_number_minmax" id="h`NGKEG*S3^GaDluhLlg"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">0</field></shadow></value><value name="y0"><shadow type="math_number_minmax" id="e.qp4IN,++e7G%[hinrM"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">0</field></shadow></value><value name="x1"><shadow type="math_number_minmax" id="KAVQE|HZWP?HAWcHX*W9"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">127</field></shadow></value><value name="y1"><shadow type="math_number_minmax" id="TRE4{=NP.H]5~G,a6OV%"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">0</field></shadow></value><value name="height"><shadow type="math_number_minmax" id="@0Z(ZQR}@haubGFy`hM5"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">63</field></shadow></value><value name="on"><shadow type="logic_boolean" id="C_^,e1insC~1xC:{7lwr"><field name="BOOL">TRUE</field></shadow></value><next><block type="oled_show" id="XQtr[%vxokW,6!XQ+*Q{"></block></next></block></statement></block></xml>