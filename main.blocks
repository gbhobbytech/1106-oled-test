<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="VnBvR3GxmW0Q(f=_8Y1L" x="41" y="54"><statement name="HANDLER"><block type="typescript_statement" id="cLVR/7aN)R,_[FbLkvZ)"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="enum ArcDirection {" line1="    //% block=&quot;up&quot;" line2="    Up," line3="    //% block=&quot;down&quot;" line4="    Down" line5="}" numlines="6"></mutation><next><block type="typescript_statement" id="H7Vku.j$Xoa9h896|{Z+"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="" line4="    let buffer = pins.createBuffer(1024)" line5="    let started = false" line6="" line7="    function cmd(c: number): void {" line8="        let b = pins.createBuffer(2)" line9="        b[0] = 0x00" line10="        b[1] = c" line11="        pins.i2cWriteBuffer(OLED_ADDR, b)" line12="    }" line13="" line14="    function data(buf: Buffer): void {" line15="        let out = pins.createBuffer(buf.length + 1)" line16="        out[0] = 0x40" line17="        for (let i = 0; i &lt; buf.length; i++) {" line18="            out[i + 1] = buf[i]" line19="        }" line20="        pins.i2cWriteBuffer(OLED_ADDR, out)" line21="    }" line22="" line23="    function setPage(page: number): void {" line24="        cmd(0xB0 | page)" line25="        cmd(OFFSET &amp; 0x0F)" line26="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line27="    }" line28="" line29="    //% block=&quot;initialise OLED&quot;" line30="    //% group=&quot;Basic&quot;" line31="    export function init(): void {" line32="        basic.pause(100)" line33="" line34="        cmd(0xAE)              // display off" line35="        cmd(0xD5); cmd(0x80)   // clock divide" line36="        cmd(0xA8); cmd(0x3F)   // multiplex ratio 64" line37="        cmd(0xD3); cmd(0x00)   // display offset" line38="        cmd(0x40)              // display start line" line39="        cmd(0xA1)              // segment remap" line40="        cmd(0xC8)              // COM scan direction" line41="        cmd(0xDA); cmd(0x12)   // COM pins" line42="        cmd(0x81); cmd(0x7F)   // contrast" line43="        cmd(0xD9); cmd(0x22)   // pre-charge" line44="        cmd(0xDB); cmd(0x20)   // VCOMH deselect" line45="        cmd(0xA4)              // resume display from RAM" line46="        cmd(0xA6)              // normal display" line47="        cmd(0xAF)              // display on" line48="" line49="        started = true" line50="        clear()" line51="        show()" line52="    }" line53="" line54="    //% block=&quot;clear drawing&quot;" line55="    //% group=&quot;Advanced&quot;" line56="    export function clear(): void {" line57="        for (let j = 0; j &lt; 1024; j++) {" line58="            buffer[j] = 0" line59="        }" line60="    }" line61="" line62="    //% block=&quot;fill screen %on&quot;" line63="    //% group=&quot;Advanced&quot;" line64="    export function fill(on: boolean): void {" line65="        let value = on ? 0xFF : 0x00" line66="        for (let k = 0; k &lt; 1024; k++) {" line67="            buffer[k] = value" line68="        }" line69="    }" line70="" line71="    //% block=&quot;update OLED&quot;" line72="    //% group=&quot;Basic&quot;" line73="    export function show(): void {" line74="        if (!started) {" line75="            init()" line76="            return" line77="        }" line78="" line79="        for (let page = 0; page &lt; 8; page++) {" line80="            setPage(page)" line81="" line82="            let row = pins.createBuffer(128)" line83="            for (let x = 0; x &lt; 128; x++) {" line84="                row[x] = buffer[page * 128 + x]" line85="            }" line86="" line87="            data(row)" line88="        }" line89="    }" line90="" line91="    //% block=&quot;plot pixel x %x y %y on %on&quot;" line92="    //% group=&quot;Advanced&quot;" line93="    //% x.min=0 x.max=127 y.min=0 y.max=63" line94="    export function pixel(x: number, y: number, on: boolean): void {" line95="        if (x &lt; 0 || x &gt; 127 || y &lt; 0 || y &gt; 63) {" line96="            return" line97="        }" line98="" line99="        let page2 = Math.idiv(y, 9)" line100="        let index = page2 * 128 + x" line101="        let mask = 1 &lt;&lt; (y % 9)" line102="" line103="        if (on) {" line104="            buffer[index] = buffer[index] | mask" line105="        } else {" line106="            buffer[index] = buffer[index] &amp; ~mask" line107="        }" line108="    }" line109="    " line110="    " line111="    //% blockId=oled_create_icon" line112="    //% block=&quot;icon&quot;" line113="    //% imageLiteral=1" line114="    //% imageLiteralColumns=9" line115="    //% imageLiteralRows=9" line116="    //% shim=images::createImage" line117="    //% weight=0" line118="    export function createIcon(leds: string): Image {" line119="        return &lt;Image&gt;&lt;any&gt;leds" line120="    }" line121="" line122="    //% blockId=oled_draw_icon" line123="    //% block=&quot;draw icon $img at x $x y $y on $on&quot;" line124="    //% group=&quot;Drawing&quot;" line125="    //% img.shadow=oled_create_icon" line126="    //% x.min=0 x.max=127" line127="    //% y.min=0 y.max=63" line128="    export function drawIcon(img: Image, x: number, y: number, on: boolean = true): void {" line129="        for (let yy = 0; yy &lt; 9; yy++) {" line130="            for (let xx = 0; xx &lt; 9; xx++) {" line131="                if (img.pixel(xx, yy)) {" line132="                    pixel(x + xx, y + yy, on)" line133="                }" line134="            }" line135="        }" line136="    }" line137="" line138="" line139="    //% block=&quot;draw line from start x %startX y %startY to end x %endX y %endY on %on&quot;" line140="    //% group=&quot;Drawing&quot;" line141="    //% x0.min=0 x0.max=127 y0.min=0 y0.max=63" line142="    //% x1.min=0 x1.max=127 y1.min=0 y1.max=63" line143="    export function line(x0: number, y0: number, x1: number, y1: number, on: boolean = true): void {" line144="        let dx = Math.abs(x1 - x0)" line145="        let sx = x0 &lt; x1 ? 1 : -1" line146="        let dy = -Math.abs(y1 - y0)" line147="        let sy = y0 &lt; y1 ? 1 : -1" line148="        let err = dx + dy" line149="" line150="        while (true) {" line151="            pixel(x0, y0, on)" line152="" line153="            if (x0 == x1 &amp;&amp; y0 == y1) {" line154="                break" line155="            }" line156="" line157="            let e2 = 2 * err" line158="" line159="            if (e2 &gt;= dy) {" line160="                err += dy" line161="                x0 += sx" line162="            }" line163="" line164="            if (e2 &lt;= dx) {" line165="                err += dx" line166="                y0 += sy" line167="            }" line168="        }" line169="    }" line170="" line171="    //% block=&quot;draw rectangle x %x y %y width %w height %h on %on&quot;" line172="    //% group=&quot;Drawing&quot;" line173="    //% x.min=0 x.max=127 y.min=0 y.max=63" line174="    //% w.min=0 w.max=127 h.min=0 h.max=63" line175="    export function rect(x: number, y: number, w: number, h: number, on: boolean = true): void {" line176="        line(x, y, x + w, y, on)" line177="        line(x, y, x, y + h, on)" line178="        line(x + w, y, x + w, y + h, on)" line179="        line(x, y + h, x + w, y + h, on)" line180="    }" line181="" line182="    function fillRect(x: number, y: number, w: number, h: number, on: boolean): void {" line183="        for (let yy2 = y; yy2 &lt; y + h; yy2++) {" line184="            for (let xx2 = x; xx2 &lt; x + w; xx2++) {" line185="                pixel(xx2, yy2, on)" line186="            }" line187="        }" line188="    }" line189="" line190="    //% block=&quot;draw circle x %cx y %cy radius %r on %on&quot;" line191="    //% group=&quot;Drawing&quot;" line192="    //% cx.min=0 cx.max=127 cy.min=0 cy.max=63 r.min=1 r.max=63" line193="    export function circle(cx: number, cy: number, r: number, on: boolean = true): void {" line194="        let x2 = r" line195="        let y = 0" line196="        let err2 = 0" line197="" line198="        while (x2 &gt;= y) {" line199="            pixel(cx + x2, cy + y, on)" line200="            pixel(cx + y, cy + x2, on)" line201="            pixel(cx - y, cy + x2, on)" line202="            pixel(cx - x2, cy + y, on)" line203="            pixel(cx - x2, cy - y, on)" line204="            pixel(cx - y, cy - x2, on)" line205="            pixel(cx + y, cy - x2, on)" line206="            pixel(cx + x2, cy - y, on)" line207="" line208="            y += 1" line209="" line210="            if (err2 &lt;= 0) {" line211="                err2 += 2 * y + 1" line212="            } else {" line213="                x2 -= 1" line214="                err2 += 2 * (y - x2) + 1" line215="            }" line216="        }" line217="    }" line218="    " line219="    //% block=&quot;draw arc from start x %x0 y %y0 to end x %x1 y %y1 height %height direction %direction on %on&quot;" line220="    //% group=&quot;Drawing&quot;" line221="    //% x0.min=0 x0.max=127 y0.min=0 y0.max=63" line222="    //% x1.min=0 x1.max=127 y1.min=0 y1.max=63" line223="    //% height.min=0 height.max=63" line224="    export function arc(x0: number, y0: number, x1: number, y1: number, height: number, direction: ArcDirection, on: boolean = true): void {" line225="        if (height &lt; 0) {" line226="            height = 0" line227="        }" line228="" line229="        let midX = Math.idiv(x0 + x1, 2)" line230="        let midY = Math.idiv(y0 + y1, 2)" line231="" line232="        let controlX = midX" line233="        let controlY = midY" line234="" line235="        // A quadratic curve only reaches about half way toward the control point." line236="        // Doubling this makes the visible arc height match the height entered." line237="        let controlHeight = height * 2" line238="" line239="        if (direction == ArcDirection.Up) {" line240="            controlY = midY - controlHeight" line241="        } else {" line242="            controlY = midY + controlHeight" line243="        }" line244="" line245="        let dx2 = Math.abs(x1 - x0)" line246="        let dy2 = Math.abs(y1 - y0)" line247="        let steps = dx2" line248="" line249="        if (dy2 &gt; steps) {" line250="            steps = dy2" line251="        }" line252="" line253="        steps = steps * 2" line254="" line255="        if (steps &lt; 1) {" line256="            steps = 1" line257="        }" line258="" line259="        let lastX = x0" line260="        let lastY = y0" line261="" line262="        for (let l = 1; l &lt;= steps; l++) {" line263="            let t = l / steps" line264="            let oneMinusT = 1 - t" line265="" line266="            let x3 = Math.round(" line267="                oneMinusT * oneMinusT * x0 +" line268="                2 * oneMinusT * t * controlX +" line269="                t * t * x1" line270="            )" line271="" line272="            let y2 = Math.round(" line273="                oneMinusT * oneMinusT * y0 +" line274="                2 * oneMinusT * t * controlY +" line275="                t * t * y1" line276="            )" line277="" line278="            line(lastX, lastY, x3, y2, on)" line279="" line280="            lastX = x3" line281="            lastY = y2" line282="        }" line283="    }" line284="" line285="    //% block=&quot;draw solid circle x %cx y %cy radius %r on %on&quot;" line286="    //% group=&quot;Drawing&quot;" line287="    //% cx.min=0 cx.max=127 cy.min=0 cy.max=63 r.min=1 r.max=63" line288="    export function fillCircle(cx: number, cy: number, r: number, on: boolean = true): void {" line289="        for (let y22 = -r; y22 &lt;= r; y22++) {" line290="            for (let x32 = -r; x32 &lt;= r; x32++) {" line291="                if (x32 * x32 + y22 * y22 &lt;= r * r) {" line292="                    pixel(cx + x32, cy + y22, on)" line293="                }" line294="            }" line295="        }" line296="    }" line297="" line298="    const font5x7: number[] = [" line299="        0x00, 0x00, 0x00, 0x00, 0x00, // space" line300="        0x00, 0x00, 0x5F, 0x00, 0x00, // !" line301="        0x00, 0x07, 0x00, 0x07, 0x00, // &quot;" line302="        0x14, 0x7F, 0x14, 0x7F, 0x14, // #" line303="        0x24, 0x2A, 0x7F, 0x2A, 0x12, // $" line304="        0x23, 0x13, 0x08, 0x64, 0x62, // %" line305="        0x36, 0x49, 0x55, 0x22, 0x50, // &amp;" line306="        0x00, 0x05, 0x03, 0x00, 0x00, // '" line307="        0x00, 0x1C, 0x22, 0x41, 0x00, // (" line308="        0x00, 0x41, 0x22, 0x1C, 0x00, // )" line309="        0x14, 0x08, 0x3E, 0x08, 0x14, // *" line310="        0x08, 0x08, 0x3E, 0x08, 0x08, // +" line311="        0x00, 0x50, 0x30, 0x00, 0x00, // ," line312="        0x08, 0x08, 0x08, 0x08, 0x08, // -" line313="        0x00, 0x60, 0x60, 0x00, 0x00, // ." line314="        0x20, 0x10, 0x08, 0x04, 0x02, // /" line315="        0x3E, 0x51, 0x49, 0x45, 0x3E, // 0" line316="        0x00, 0x42, 0x7F, 0x40, 0x00, // 1" line317="        0x42, 0x61, 0x51, 0x49, 0x46, // 2" line318="        0x21, 0x41, 0x45, 0x4B, 0x31, // 3" line319="        0x18, 0x14, 0x12, 0x7F, 0x10, // 4" line320="        0x27, 0x45, 0x45, 0x45, 0x39, // 5" line321="        0x3C, 0x4A, 0x49, 0x49, 0x30, // 6" line322="        0x01, 0x71, 0x09, 0x05, 0x03, // 7" line323="        0x36, 0x49, 0x49, 0x49, 0x36, // 8" line324="        0x06, 0x49, 0x49, 0x29, 0x1E, // 9" line325="        0x00, 0x36, 0x36, 0x00, 0x00, // :" line326="        0x00, 0x56, 0x36, 0x00, 0x00, // ;" line327="        0x08, 0x14, 0x22, 0x41, 0x00, // &lt;" line328="        0x14, 0x14, 0x14, 0x14, 0x14, // =" line329="        0x00, 0x41, 0x22, 0x14, 0x08, // &gt;" line330="        0x02, 0x01, 0x51, 0x09, 0x06, // ?" line331="        0x32, 0x49, 0x79, 0x41, 0x3E, // @" line332="        0x7E, 0x11, 0x11, 0x11, 0x7E, // A" line333="        0x7F, 0x49, 0x49, 0x49, 0x36, // B" line334="        0x3E, 0x41, 0x41, 0x41, 0x22, // C" line335="        0x7F, 0x41, 0x41, 0x22, 0x1C, // D" line336="        0x7F, 0x49, 0x49, 0x49, 0x41, // E" line337="        0x7F, 0x09, 0x09, 0x09, 0x01, // F" line338="        0x3E, 0x41, 0x49, 0x49, 0x7A, // G" line339="        0x7F, 0x08, 0x08, 0x08, 0x7F, // H" line340="        0x00, 0x41, 0x7F, 0x41, 0x00, // I" line341="        0x20, 0x40, 0x41, 0x3F, 0x01, // J" line342="        0x7F, 0x08, 0x14, 0x22, 0x41, // K" line343="        0x7F, 0x40, 0x40, 0x40, 0x40, // L" line344="        0x7F, 0x02, 0x0C, 0x02, 0x7F, // M" line345="        0x7F, 0x04, 0x08, 0x10, 0x7F, // N" line346="        0x3E, 0x41, 0x41, 0x41, 0x3E, // O" line347="        0x7F, 0x09, 0x09, 0x09, 0x06, // P" line348="        0x3E, 0x41, 0x51, 0x21, 0x5E, // Q" line349="        0x7F, 0x09, 0x19, 0x29, 0x46, // R" line350="        0x46, 0x49, 0x49, 0x49, 0x31, // S" line351="        0x01, 0x01, 0x7F, 0x01, 0x01, // T" line352="        0x3F, 0x40, 0x40, 0x40, 0x3F, // U" line353="        0x1F, 0x20, 0x40, 0x20, 0x1F, // V" line354="        0x3F, 0x40, 0x38, 0x40, 0x3F, // W" line355="        0x63, 0x14, 0x08, 0x14, 0x63, // X" line356="        0x07, 0x08, 0x70, 0x08, 0x07, // Y" line357="        0x61, 0x51, 0x49, 0x45, 0x43  // Z" line358="    ]" line359="" line360="    function drawChar(ch: string, x: number, y: number, size: number, on: boolean): void {" line361="        let code = ch.charCodeAt(0)" line362="" line363="        if (code &gt;= 97 &amp;&amp; code &lt;= 122) {" line364="            code -= 32" line365="        }" line366="" line367="        if (code &lt; 32 || code &gt; 90) {" line368="            code = 63" line369="        }" line370="" line371="        let index2 = (code - 32) * 5" line372="" line373="        for (let col = 0; col &lt; 5; col++) {" line374="            let lineBits = font5x7[index2 + col]" line375="" line376="            for (let row2 = 0; row2 &lt; 7; row2++) {" line377="                if ((lineBits &amp; (1 &lt;&lt; row2)) != 0) {" line378="                    if (size &lt;= 1) {" line379="                        pixel(x + col, y + row2, on)" line380="                    } else {" line381="                        fillRect(x + col * size, y + row2 * size, size, size, on)" line382="                    }" line383="                }" line384="            }" line385="        }" line386="    }" line387="" line388="    //% block=&quot;show text %message x %x y %y size %size&quot;" line389="    //% group=&quot;Basic&quot;" line390="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line391="    export function showText(message: string, x: number, y: number, size: number = 1): void {" line392="        if (!started) {" line393="            init()" line394="        }" line395="" line396="        clear()" line397="        text(message, x, y, size, true)" line398="        show()" line399="    }" line400="" line401="    //% block=&quot;draw text %message x %x y %y size %size on %on&quot;" line402="    //% group=&quot;Advanced&quot;" line403="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line404="    export function text(message: string, x: number, y: number, size: number = 1, on: boolean = true): void {" line405="        if (size &lt; 1) {" line406="            size = 1" line407="        }" line408="        if (size &gt; 4) {" line409="            size = 4" line410="        }" line411="" line412="        for (let m = 0; m &lt; message.length; m++) {" line413="            drawChar(message.charAt(m), x + m * 6 * size, y, size, on)" line414="        }" line415="    }" line416="" line417="}" numlines="418"></mutation></block></next></block></statement></block></xml>