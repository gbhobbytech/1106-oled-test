<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="Ncg`z7uWSF;[K93*wc@T" x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id="7iPI1$!o+4p2QK(Xjzwi"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="    let buffer = pins.createBuffer(1024)" line4="    let started = false" line5="" line6="    function cmd(c: number) {" line7="        let b = pins.createBuffer(2)" line8="        b[0] = 0x00" line9="        b[1] = c" line10="        pins.i2cWriteBuffer(OLED_ADDR, b)" line11="    }" line12="" line13="    function data(buf: Buffer) {" line14="        let out = pins.createBuffer(buf.length + 1)" line15="        out[0] = 0x40" line16="        for (let i = 0; i &lt; buf.length; i++) {" line17="            out[i + 1] = buf[i]" line18="        }" line19="        pins.i2cWriteBuffer(OLED_ADDR, out)" line20="    }" line21="" line22="    function setPage(page: number) {" line23="        cmd(0xB0 | page)" line24="        cmd(OFFSET &amp; 0x0F)" line25="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line26="    }" line27="" line28="    //% block=&quot;initialise OLED&quot;" line29="    export function init(): void {" line30="        basic.pause(100)" line31="" line32="        cmd(0xAE)" line33="        cmd(0xD5); cmd(0x80)" line34="        cmd(0xA8); cmd(0x3F)" line35="        cmd(0xD3); cmd(0x00)" line36="        cmd(0x40)" line37="        cmd(0xA1)" line38="        cmd(0xC8)" line39="        cmd(0xDA); cmd(0x12)" line40="        cmd(0x81); cmd(0x7F)" line41="        cmd(0xD9); cmd(0x22)" line42="        cmd(0xDB); cmd(0x20)" line43="        cmd(0xA4)" line44="        cmd(0xA6)" line45="        cmd(0xAF)" line46="" line47="        cmd(0xAF)" line48="" line49="        started = true" line50="        clear()" line51="        show()" line52="        " line53="    }" line54="" line55="    //% block=&quot;clear OLED buffer&quot;" line56="    export function clear(): void {" line57="        for (let j = 0; j &lt; 1024; j++) {" line58="            buffer[j] = 0" line59="        }" line60="    }" line61="" line62="    //% block=&quot;show OLED&quot;" line63="    export function show(): void {" line64="        if (!started) {" line65="            init()" line66="        }" line67="" line68="        for (let page = 0; page &lt; 8; page++) {" line69="            setPage(page)" line70="" line71="            let row = pins.createBuffer(128)" line72="            for (let x = 0; x &lt; 128; x++) {" line73="                row[x] = buffer[page * 128 + x]" line74="            }" line75="" line76="            data(row)" line77="        }" line78="    }" line79="" line80="    //% block=&quot;plot OLED pixel x %x y %y on %on&quot;" line81="    //% x.min=0 x.max=127 y.min=0 y.max=63" line82="    export function pixel(x: number, y: number, on: boolean): void {" line83="        if (x &lt; 0 || x &gt; 127 || y &lt; 0 || y &gt; 63) {" line84="            return" line85="        }" line86="" line87="        let page2 = Math.idiv(y, 8)" line88="        let index = page2 * 128 + x" line89="        let mask = 1 &lt;&lt; (y % 8)" line90="" line91="        if (on) {" line92="            buffer[index] = buffer[index] | mask" line93="        } else {" line94="            buffer[index] = buffer[index] &amp; ~mask" line95="        }" line96="    }" line97="    //% block=&quot;draw line x0 %x0 y0 %y0 x1 %x1 y1 %y1&quot;" line98="    export function line(x0: number, y0: number, x1: number, y1: number): void {" line99="        let dx = Math.abs(x1 - x0)" line100="        let sx = x0 &lt; x1 ? 1 : -1" line101="        let dy = -Math.abs(y1 - y0)" line102="        let sy = y0 &lt; y1 ? 1 : -1" line103="        let err = dx + dy" line104="" line105="        while (true) {" line106="            pixel(x0, y0, true)" line107="" line108="            if (x0 == x1 &amp;&amp; y0 == y1) break" line109="" line110="            let e2 = 2 * err" line111="" line112="            if (e2 &gt;= dy) {" line113="                err += dy" line114="                x0 += sx" line115="            }" line116="" line117="            if (e2 &lt;= dx) {" line118="                err += dx" line119="                y0 += sy" line120="            }" line121="        }" line122="    }" line123="    //% block=&quot;fill OLED buffer %on&quot;" line124="    export function fill(on: boolean): void {" line125="        let value = on ? 0xFF : 0x00" line126="" line127="        for (let k = 0; k &lt; 1024; k++) {" line128="            buffer[k] = value" line129="        }" line130="    }" line131="}" numlines="132"></mutation></block></statement></block></xml>