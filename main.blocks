<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="y][j(MXLdf:3lrl3P2,X" x="0" y="0"><statement name="HANDLER"><block type="typescript_statement" id="=3^iOiwg$xAc2JWM+X7/"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="    let buffer = pins.createBuffer(1024)" line4="    let started = false" line5="" line6="    function cmd(c: number) {" line7="        let b = pins.createBuffer(2)" line8="        b[0] = 0x00" line9="        b[1] = c" line10="        pins.i2cWriteBuffer(OLED_ADDR, b)" line11="    }" line12="" line13="    function data(buf: Buffer) {" line14="        let out = pins.createBuffer(buf.length + 1)" line15="        out[0] = 0x40" line16="        for (let i = 0; i &lt; buf.length; i++) {" line17="            out[i + 1] = buf[i]" line18="        }" line19="        pins.i2cWriteBuffer(OLED_ADDR, out)" line20="    }" line21="" line22="    function setPage(page: number) {" line23="        cmd(0xB0 | page)" line24="        cmd(OFFSET &amp; 0x0F)" line25="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line26="    }" line27="" line28="    //% block=&quot;initialise OLED&quot;" line29="    export function init(): void {" line30="        basic.pause(100)" line31="" line32="        cmd(0xAE)" line33="        cmd(0xD5); cmd(0x80)" line34="        cmd(0xA8); cmd(0x3F)" line35="        cmd(0xD3); cmd(0x00)" line36="        cmd(0x40)" line37="        cmd(0xA1)" line38="        cmd(0xC8)" line39="        cmd(0xDA); cmd(0x12)" line40="        cmd(0x81); cmd(0x7F)" line41="        cmd(0xD9); cmd(0x22)" line42="        cmd(0xDB); cmd(0x20)" line43="        cmd(0xA4)" line44="        cmd(0xA6)" line45="        cmd(0xAF)" line46="" line47="        cmd(0xAF)" line48="" line49="        started = true" line50="        clear()" line51="        show()" line52="        " line53="    }" line54="" line55="    //% block=&quot;clear OLED buffer&quot;" line56="    export function clear(): void {" line57="        for (let j = 0; j &lt; 1024; j++) {" line58="            buffer[j] = 0" line59="        }" line60="    }" line61="" line62="    //% block=&quot;show OLED&quot;" line63="    export function show(): void {" line64="        if (!started) {" line65="            init()" line66="        }" line67="" line68="        for (let page = 0; page &lt; 8; page++) {" line69="            setPage(page)" line70="" line71="            let row = pins.createBuffer(128)" line72="            for (let x = 0; x &lt; 128; x++) {" line73="                row[x] = buffer[page * 128 + x]" line74="            }" line75="" line76="            data(row)" line77="        }" line78="    }" line79="" line80="    //% block=&quot;plot OLED pixel x %x y %y on %on&quot;" line81="    //% x.min=0 x.max=127 y.min=0 y.max=63" line82="    export function pixel(x: number, y: number, on: boolean): void {" line83="        if (x &lt; 0 || x &gt; 127 || y &lt; 0 || y &gt; 63) {" line84="            return" line85="        }" line86="" line87="        let page2 = Math.idiv(y, 8)" line88="        let index = page2 * 128 + x" line89="        let mask = 1 &lt;&lt; (y % 8)" line90="" line91="        if (on) {" line92="            buffer[index] = buffer[index] | mask" line93="        } else {" line94="            buffer[index] = buffer[index] &amp; ~mask" line95="        }" line96="    }" line97="" line98="    //% block=&quot;fill OLED buffer %on&quot;" line99="    export function fill(on: boolean): void {" line100="        let value = on ? 0xFF : 0x00" line101="" line102="        for (let k = 0; k &lt; 1024; k++) {" line103="            buffer[k] = value" line104="        }" line105="    }" line106="}" numlines="107"></mutation><next><block type="oled_init" id="wuD.!`@Ik9*TS_aX8:=w"></block></next></block></statement></block><block type="device_forever" id="W]Mm`XS4AZgo?2wT0X#b" x="659" y="3889"><statement name="HANDLER"><block type="oled_pixel" id="h+Dy#Pd:X8SR0y---lcy"><value name="x"><shadow type="math_number_minmax" id="t[PYmCNfHUBgP.Kco-9e"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">10</field></shadow></value><value name="y"><shadow type="math_number_minmax" id="||e@~Oys:`!4CZa.@nQR"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">10</field></shadow></value><value name="on"><shadow type="logic_boolean" id="J!T$zc53DbS]vAD+BgbU"><field name="BOOL">TRUE</field></shadow></value><next><block type="oled_pixel" id="4j{|*QEqPJfs5!cI1`?2"><value name="x"><shadow type="math_number_minmax" id="P+jmi?P$3CF1oeXDYeBj"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">20</field></shadow></value><value name="y"><shadow type="math_number_minmax" id="eX;9?5#ujCUt25=`C)KG"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">20</field></shadow></value><value name="on"><shadow type="logic_boolean" id="Bho^5awzn5|/|{:zC#zN"><field name="BOOL">TRUE</field></shadow></value><next><block type="oled_pixel" id="JhXX42S{|uheX=k]9V|E"><value name="x"><shadow type="math_number_minmax" id="Ry@~A+aW;^3h9jjsN1HN"><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">30</field></shadow></value><value name="y"><shadow type="math_number_minmax" id=";|/O41hE$@2N4_4KQ3YN"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">30</field></shadow></value><value name="on"><shadow type="logic_boolean" id="z0R`X~4Q0Qgw!.nf7++J"><field name="BOOL">TRUE</field></shadow></value><next><block type="oled_pixel" id="0E?4kgVx|75A.UkRIje0"><value name="x"><shadow type="math_number_minmax" id="Ok%+ubb,:mjnKp7*D:^("><mutation min="0" max="127" precision="0"></mutation><field name="SLIDER">40</field></shadow></value><value name="y"><shadow type="math_number_minmax" id="wM},3.8EQJ6-cS4VR)KX"><mutation min="0" max="63" precision="0"></mutation><field name="SLIDER">40</field></shadow></value><value name="on"><shadow type="logic_boolean" id="yET]OcwMY-yLL+~}^-Oe"><field name="BOOL">TRUE</field></shadow></value><next><block type="oled_show" id="O]/15:6H%/q2uOm4k}NT"></block></next></block></next></block></next></block></next></block></statement></block></xml>