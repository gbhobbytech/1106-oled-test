<xml xmlns="https://developers.google.com/blockly/xml"><variables></variables><block type="pxt-on-start" id="JaZJ-UjX$*t!Rl^axK{." x="20" y="20"><statement name="HANDLER"><block type="typescript_statement" id=".IafrA6e!y1a6p;}nkO,"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="namespace oled {" line1="    const OLED_ADDR = 0x3C" line2="    const OFFSET = 2" line3="" line4="    let buffer = pins.createBuffer(1024)" line5="    let started = false" line6="" line7="    function cmd(c: number): void {" line8="        let b = pins.createBuffer(2)" line9="        b[0] = 0x00" line10="        b[1] = c" line11="        pins.i2cWriteBuffer(OLED_ADDR, b)" line12="    }" line13="" line14="    function data(buf: Buffer): void {" line15="        let out = pins.createBuffer(buf.length + 1)" line16="        out[0] = 0x40" line17="        for (let i = 0; i &lt; buf.length; i++) {" line18="            out[i + 1] = buf[i]" line19="        }" line20="        pins.i2cWriteBuffer(OLED_ADDR, out)" line21="    }" line22="" line23="    function setPage(page: number): void {" line24="        cmd(0xB0 | page)" line25="        cmd(OFFSET &amp; 0x0F)" line26="        cmd(0x10 | ((OFFSET &gt;&gt; 4) &amp; 0x0F))" line27="    }" line28="" line29="    //% block=&quot;initialise OLED&quot;" line30="    //% group=&quot;Basic&quot;" line31="    export function init(): void {" line32="        basic.pause(100)" line33="" line34="        cmd(0xAE)              // display off" line35="        cmd(0xD5); cmd(0x80)   // clock divide" line36="        cmd(0xA8); cmd(0x3F)   // multiplex ratio 64" line37="        cmd(0xD3); cmd(0x00)   // display offset" line38="        cmd(0x40)              // display start line" line39="        cmd(0xA1)              // segment remap" line40="        cmd(0xC8)              // COM scan direction" line41="        cmd(0xDA); cmd(0x12)   // COM pins" line42="        cmd(0x81); cmd(0x7F)   // contrast" line43="        cmd(0xD9); cmd(0x22)   // pre-charge" line44="        cmd(0xDB); cmd(0x20)   // VCOMH deselect" line45="        cmd(0xA4)              // resume display from RAM" line46="        cmd(0xA6)              // normal display" line47="        cmd(0xAF)              // display on" line48="" line49="        started = true" line50="        clear()" line51="        show()" line52="    }" line53="" line54="    //% block=&quot;clear drawing&quot;" line55="    //% group=&quot;Advanced&quot;" line56="    export function clear(): void {" line57="        for (let j = 0; j &lt; 1024; j++) {" line58="            buffer[j] = 0" line59="        }" line60="    }" line61="" line62="    //% block=&quot;fill screen %on&quot;" line63="    //% group=&quot;Advanced&quot;" line64="    export function fill(on: boolean): void {" line65="        let value = on ? 0xFF : 0x00" line66="        for (let k = 0; k &lt; 1024; k++) {" line67="            buffer[k] = value" line68="        }" line69="    }" line70="" line71="    //% block=&quot;update OLED&quot;" line72="    //% group=&quot;Advanced&quot;" line73="    export function show(): void {" line74="        if (!started) {" line75="            init()" line76="            return" line77="        }" line78="" line79="        for (let page = 0; page &lt; 8; page++) {" line80="            setPage(page)" line81="" line82="            let row = pins.createBuffer(128)" line83="            for (let x = 0; x &lt; 128; x++) {" line84="                row[x] = buffer[page * 128 + x]" line85="            }" line86="" line87="            data(row)" line88="        }" line89="    }" line90="" line91="    //% block=&quot;plot pixel x %x y %y on %on&quot;" line92="    //% group=&quot;Advanced&quot;" line93="    //% x.min=0 x.max=127 y.min=0 y.max=63" line94="    export function pixel(x: number, y: number, on: boolean): void {" line95="        if (x &lt; 0 || x &gt; 127 || y &lt; 0 || y &gt; 63) {" line96="            return" line97="        }" line98="" line99="        let page2 = Math.idiv(y, 8)" line100="        let index = page2 * 128 + x" line101="        let mask = 1 &lt;&lt; (y % 8)" line102="" line103="        if (on) {" line104="            buffer[index] = buffer[index] | mask" line105="        } else {" line106="            buffer[index] = buffer[index] &amp; ~mask" line107="        }" line108="    }" line109="" line110="    //% block=&quot;draw line x0 %x0 y0 %y0 x1 %x1 y1 %y1 on %on&quot;" line111="    //% group=&quot;Drawing&quot;" line112="    //% x0.min=0 x0.max=127 y0.min=0 y0.max=63" line113="    //% x1.min=0 x1.max=127 y1.min=0 y1.max=63" line114="    export function line(x0: number, y0: number, x1: number, y1: number, on: boolean = true): void {" line115="        let dx = Math.abs(x1 - x0)" line116="        let sx = x0 &lt; x1 ? 1 : -1" line117="        let dy = -Math.abs(y1 - y0)" line118="        let sy = y0 &lt; y1 ? 1 : -1" line119="        let err = dx + dy" line120="" line121="        while (true) {" line122="            pixel(x0, y0, on)" line123="" line124="            if (x0 == x1 &amp;&amp; y0 == y1) {" line125="                break" line126="            }" line127="" line128="            let e2 = 2 * err" line129="" line130="            if (e2 &gt;= dy) {" line131="                err += dy" line132="                x0 += sx" line133="            }" line134="" line135="            if (e2 &lt;= dx) {" line136="                err += dx" line137="                y0 += sy" line138="            }" line139="        }" line140="    }" line141="" line142="    //% block=&quot;draw rectangle x %x y %y width %w height %h on %on&quot;" line143="    //% group=&quot;Drawing&quot;" line144="    //% x.min=0 x.max=127 y.min=0 y.max=63" line145="    //% w.min=0 w.max=127 h.min=0 h.max=63" line146="    export function rect(x: number, y: number, w: number, h: number, on: boolean = true): void {" line147="        line(x, y, x + w, y, on)" line148="        line(x, y, x, y + h, on)" line149="        line(x + w, y, x + w, y + h, on)" line150="        line(x, y + h, x + w, y + h, on)" line151="    }" line152="" line153="    function fillRect(x: number, y: number, w: number, h: number, on: boolean): void {" line154="        for (let yy = y; yy &lt; y + h; yy++) {" line155="            for (let xx = x; xx &lt; x + w; xx++) {" line156="                pixel(xx, yy, on)" line157="            }" line158="        }" line159="    }" line160="" line161="    //% block=&quot;draw circle x %cx y %cy radius %r on %on&quot;" line162="    //% group=&quot;Drawing&quot;" line163="    //% cx.min=0 cx.max=127 cy.min=0 cy.max=63 r.min=1 r.max=63" line164="    export function circle(cx: number, cy: number, r: number, on: boolean = true): void {" line165="        let x2 = r" line166="        let y = 0" line167="        let err2 = 0" line168="" line169="        while (x2 &gt;= y) {" line170="            pixel(cx + x2, cy + y, on)" line171="            pixel(cx + y, cy + x2, on)" line172="            pixel(cx - y, cy + x2, on)" line173="            pixel(cx - x2, cy + y, on)" line174="            pixel(cx - x2, cy - y, on)" line175="            pixel(cx - y, cy - x2, on)" line176="            pixel(cx + y, cy - x2, on)" line177="            pixel(cx + x2, cy - y, on)" line178="" line179="            y += 1" line180="" line181="            if (err2 &lt;= 0) {" line182="                err2 += 2 * y + 1" line183="            } else {" line184="                x2 -= 1" line185="                err2 += 2 * (y - x2) + 1" line186="            }" line187="        }" line188="    }" line189="" line190="    //% block=&quot;draw solid circle x %cx y %cy radius %r on %on&quot;" line191="    //% group=&quot;Drawing&quot;" line192="    //% cx.min=0 cx.max=127 cy.min=0 cy.max=63 r.min=1 r.max=63" line193="    export function fillCircle(cx: number, cy: number, r: number, on: boolean = true): void {" line194="        for (let y2 = -r; y2 &lt;= r; y2++) {" line195="            for (let x3 = -r; x3 &lt;= r; x3++) {" line196="                if (x3 * x3 + y2 * y2 &lt;= r * r) {" line197="                    pixel(cx + x3, cy + y2, on)" line198="                }" line199="            }" line200="        }" line201="    }" line202="" line203="    const font5x7: number[] = [" line204="        0x00, 0x00, 0x00, 0x00, 0x00, // space" line205="        0x00, 0x00, 0x5F, 0x00, 0x00, // !" line206="        0x00, 0x07, 0x00, 0x07, 0x00, // &quot;" line207="        0x14, 0x7F, 0x14, 0x7F, 0x14, // #" line208="        0x24, 0x2A, 0x7F, 0x2A, 0x12, // $" line209="        0x23, 0x13, 0x08, 0x64, 0x62, // %" line210="        0x36, 0x49, 0x55, 0x22, 0x50, // &amp;" line211="        0x00, 0x05, 0x03, 0x00, 0x00, // '" line212="        0x00, 0x1C, 0x22, 0x41, 0x00, // (" line213="        0x00, 0x41, 0x22, 0x1C, 0x00, // )" line214="        0x14, 0x08, 0x3E, 0x08, 0x14, // *" line215="        0x08, 0x08, 0x3E, 0x08, 0x08, // +" line216="        0x00, 0x50, 0x30, 0x00, 0x00, // ," line217="        0x08, 0x08, 0x08, 0x08, 0x08, // -" line218="        0x00, 0x60, 0x60, 0x00, 0x00, // ." line219="        0x20, 0x10, 0x08, 0x04, 0x02, // /" line220="        0x3E, 0x51, 0x49, 0x45, 0x3E, // 0" line221="        0x00, 0x42, 0x7F, 0x40, 0x00, // 1" line222="        0x42, 0x61, 0x51, 0x49, 0x46, // 2" line223="        0x21, 0x41, 0x45, 0x4B, 0x31, // 3" line224="        0x18, 0x14, 0x12, 0x7F, 0x10, // 4" line225="        0x27, 0x45, 0x45, 0x45, 0x39, // 5" line226="        0x3C, 0x4A, 0x49, 0x49, 0x30, // 6" line227="        0x01, 0x71, 0x09, 0x05, 0x03, // 7" line228="        0x36, 0x49, 0x49, 0x49, 0x36, // 8" line229="        0x06, 0x49, 0x49, 0x29, 0x1E, // 9" line230="        0x00, 0x36, 0x36, 0x00, 0x00, // :" line231="        0x00, 0x56, 0x36, 0x00, 0x00, // ;" line232="        0x08, 0x14, 0x22, 0x41, 0x00, // &lt;" line233="        0x14, 0x14, 0x14, 0x14, 0x14, // =" line234="        0x00, 0x41, 0x22, 0x14, 0x08, // &gt;" line235="        0x02, 0x01, 0x51, 0x09, 0x06, // ?" line236="        0x32, 0x49, 0x79, 0x41, 0x3E, // @" line237="        0x7E, 0x11, 0x11, 0x11, 0x7E, // A" line238="        0x7F, 0x49, 0x49, 0x49, 0x36, // B" line239="        0x3E, 0x41, 0x41, 0x41, 0x22, // C" line240="        0x7F, 0x41, 0x41, 0x22, 0x1C, // D" line241="        0x7F, 0x49, 0x49, 0x49, 0x41, // E" line242="        0x7F, 0x09, 0x09, 0x09, 0x01, // F" line243="        0x3E, 0x41, 0x49, 0x49, 0x7A, // G" line244="        0x7F, 0x08, 0x08, 0x08, 0x7F, // H" line245="        0x00, 0x41, 0x7F, 0x41, 0x00, // I" line246="        0x20, 0x40, 0x41, 0x3F, 0x01, // J" line247="        0x7F, 0x08, 0x14, 0x22, 0x41, // K" line248="        0x7F, 0x40, 0x40, 0x40, 0x40, // L" line249="        0x7F, 0x02, 0x0C, 0x02, 0x7F, // M" line250="        0x7F, 0x04, 0x08, 0x10, 0x7F, // N" line251="        0x3E, 0x41, 0x41, 0x41, 0x3E, // O" line252="        0x7F, 0x09, 0x09, 0x09, 0x06, // P" line253="        0x3E, 0x41, 0x51, 0x21, 0x5E, // Q" line254="        0x7F, 0x09, 0x19, 0x29, 0x46, // R" line255="        0x46, 0x49, 0x49, 0x49, 0x31, // S" line256="        0x01, 0x01, 0x7F, 0x01, 0x01, // T" line257="        0x3F, 0x40, 0x40, 0x40, 0x3F, // U" line258="        0x1F, 0x20, 0x40, 0x20, 0x1F, // V" line259="        0x3F, 0x40, 0x38, 0x40, 0x3F, // W" line260="        0x63, 0x14, 0x08, 0x14, 0x63, // X" line261="        0x07, 0x08, 0x70, 0x08, 0x07, // Y" line262="        0x61, 0x51, 0x49, 0x45, 0x43  // Z" line263="    ]" line264="" line265="    function drawChar(ch: string, x: number, y: number, size: number, on: boolean): void {" line266="        let code = ch.charCodeAt(0)" line267="" line268="        if (code &gt;= 97 &amp;&amp; code &lt;= 122) {" line269="            code -= 32" line270="        }" line271="" line272="        if (code &lt; 32 || code &gt; 90) {" line273="            code = 63" line274="        }" line275="" line276="        let index2 = (code - 32) * 5" line277="" line278="        for (let col = 0; col &lt; 5; col++) {" line279="            let lineBits = font5x7[index2 + col]" line280="" line281="            for (let row2 = 0; row2 &lt; 7; row2++) {" line282="                if ((lineBits &amp; (1 &lt;&lt; row2)) != 0) {" line283="                    if (size &lt;= 1) {" line284="                        pixel(x + col, y + row2, on)" line285="                    } else {" line286="                        fillRect(x + col * size, y + row2 * size, size, size, on)" line287="                    }" line288="                }" line289="            }" line290="        }" line291="    }" line292="" line293="    //% block=&quot;show text %message x %x y %y size %size&quot;" line294="    //% group=&quot;Basic&quot;" line295="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line296="    export function showText(message: string, x: number, y: number, size: number = 1): void {" line297="        if (!started) {" line298="            init()" line299="        }" line300="" line301="        clear()" line302="        text(message, x, y, size, true)" line303="        show()" line304="    }" line305="" line306="    //% block=&quot;draw text %message x %x y %y size %size on %on&quot;" line307="    //% group=&quot;Advanced&quot;" line308="    //% x.min=0 x.max=127 y.min=0 y.max=63 size.min=1 size.max=4" line309="    export function text(message: string, x: number, y: number, size: number = 1, on: boolean = true): void {" line310="        if (size &lt; 1) {" line311="            size = 1" line312="        }" line313="        if (size &gt; 4) {" line314="            size = 4" line315="        }" line316="" line317="        for (let l = 0; l &lt; message.length; l++) {" line318="            drawChar(message.charAt(l), x + l * 6 * size, y, size, on)" line319="        }" line320="    }" line321="}" numlines="322"></mutation></block></statement></block></xml>